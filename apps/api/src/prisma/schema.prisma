generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum OrgType {
  LAW_FIRM
  CORPORATE
  GOVERNMENT
  SOLO
  ACADEMIC
}

enum OrgTier {
  FREE
  LEARN
  EDGE
  VERTEX
  ZENITH
}

model GlobalSetting {
  key       String   @id
  value     Json
  updatedAt DateTime @updatedAt
}

enum OnboardingMode {
  SELF_SERVE
  INVITE_ONLY
  ENTERPRISE_SSO
}

enum AuthProvider {
  LOCAL
  GOOGLE
  MICROSOFT
  SAML
  OIDC
  SCIM
}

enum SSOProtocol {
  SAML
  OIDC
}

enum UserTier {
  LEARN
  EDGE
  VERTEX
  ZENITH
}

enum Role {
  ORG_ADMIN
  WORKSPACE_ADMIN
  PARTNER
  FEE_EARNER
  PARALEGAL
  CLIENT
  EXTERNAL_REVIEWER
  BILLING_MANAGER
  READ_ONLY
  API_CONSUMER
  PLATFORM_ADMIN
  PLATFORM_SUPPORT
}

model Organisation {
  id             String         @id @default(uuid())
  name           String
  slug           String         @unique
  type           OrgType
  tier           OrgTier
  onboardingMode OnboardingMode
  mfaRequired    Boolean        @default(false)
  trialEndsAt    DateTime?
  isSandbox      Boolean        @default(false)
  scimEnabled    Boolean        @default(false)
  scimApiKey     String?
  dataResidency  String         @default("eu-west-2")
  isActive       Boolean        @default(true)
  metadata       Json?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  users             User[]
  invites           Invite[]
  ssoConfigs        SSOConfig[]
  refreshTokens     RefreshToken[]
  auditCertificates AuditCertificate[]
  workspaces        Workspace[]
  matters           Matter[]
  documents         Document[]
  templates         Template[]
}

model User {
  id                  String       @id @default(uuid())
  email               String       @unique
  emailVerified       Boolean      @default(false)
  emailVerifiedAt     DateTime?
  passwordHash        String?
  firstName           String
  lastName            String
  orgId               String
  roles               Role[]
  tier                UserTier
  mfaEnabled          Boolean      @default(false)
  mfaSecret           String?
  mfaEnabledAt        DateTime?
  lastLoginAt         DateTime?
  lastLoginIp         String?
  failedLoginAttempts Int          @default(0)
  lockedUntil         DateTime?
  provider            AuthProvider @default(LOCAL)
  providerId          String?
  externalId          String?
  isActive            Boolean      @default(true)
  metadata            Json?
  createdAt           DateTime     @default(now())
  updatedAt           DateTime     @updatedAt

  org                     Organisation             @relation(fields: [orgId], references: [id])
  refreshTokens           RefreshToken[]
  mfaBackupCodes          MFABackupCode[]
  emailVerificationTokens EmailVerificationToken[]
  passwordResetTokens     PasswordResetToken[]
  documentAudits          DocumentAudit[]
}

model RefreshToken {
  id        String    @id @default(uuid())
  tokenHash String    @unique
  family    String
  userId    String
  orgId     String
  deviceId  String?
  userAgent String?
  ipAddress String?
  expiresAt DateTime
  revokedAt DateTime?
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  user User         @relation(fields: [userId], references: [id])
  org  Organisation @relation(fields: [orgId], references: [id])
}

model EmailVerificationToken {
  id        String   @id @default(uuid())
  userId    String   @unique
  tokenHash String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
}

model PasswordResetToken {
  id        String    @id @default(uuid())
  userId    String
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id])
}

model MFABackupCode {
  id        String    @id @default(uuid())
  userId    String
  codeHash  String
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id])
}

model Invite {
  id         String    @id @default(uuid())
  orgId      String
  email      String
  role       String
  invitedBy  String
  tokenHash  String    @unique
  expiresAt  DateTime
  acceptedAt DateTime?
  createdAt  DateTime  @default(now())

  org Organisation @relation(fields: [orgId], references: [id])
}

model SSOConfig {
  id           String      @id @default(uuid())
  orgId        String      @unique
  protocol     SSOProtocol
  entryPoint   String?
  cert         String?
  issuer       String?
  discoveryUrl String?
  clientId     String?
  clientSecret String?
  scopes       String[]
  attributeMap Json?
  isActive     Boolean     @default(true)
  createdAt    DateTime    @default(now())

  org Organisation @relation(fields: [orgId], references: [id])
}

model AuditEvent {
  id        String   @id @default(uuid())
  userId    String?
  orgId     String?
  orgSlug   String?
  action    String
  ipAddress String?
  userAgent String?
  deviceId  String?
  result    String
  metadata  Json?
  createdAt DateTime @default(now())
}

model Department {
  id                 String      @id @default(uuid())
  orgId              String
  name               String
  code               String
  headOfDepartment   String?
  parentDepartmentId String?
  workspaces         Workspace[]
}

model MatterCounter {
  year  Int @id
  count Int @default(0)
}

model Workspace {
  id                  String            @id @default(uuid())
  name                String
  slug                String
  orgId               String
  org                 Organisation      @relation(fields: [orgId], references: [id])
  departmentId        String?
  department          Department?       @relation(fields: [departmentId], references: [id])
  type                WorkspaceType
  jurisdictionProfile Json
  status              WorkspaceStatus   @default(ACTIVE)
  metadata            Json?
  createdBy           String
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt
  members             WorkspaceMember[]
  matters             Matter[]
  documents           Document[]

  @@unique([orgId, slug])
}

model WorkspaceMember {
  id          String              @id @default(uuid())
  workspaceId String
  workspace   Workspace           @relation(fields: [workspaceId], references: [id])
  userId      String
  role        WorkspaceMemberRole @default(MEMBER)
  addedBy     String
  addedAt     DateTime            @default(now())

  @@unique([workspaceId, userId])
}

model Matter {
  id              String         @id @default(uuid())
  reference       String         @unique // LARG-2026-00123
  title           String
  type            MatterType
  practiceArea    PracticeArea
  status          MatterStatus   @default(OPEN)
  priority        MatterPriority @default(MEDIUM)
  workspaceId     String
  workspace       Workspace      @relation(fields: [workspaceId], references: [id])
  orgId           String
  org             Organisation   @relation(fields: [orgId], references: [id])
  clientId        String?
  leadSolicitorId String
  counterparties  Json?
  jurisdictions   String[]
  budget          Decimal?       @db.Decimal(12, 2)
  budgetCurrency  String         @default("GBP")
  timeRecorded    Decimal        @default(0) @db.Decimal(10, 2)
  riskScore       Int            @default(0)
  confidential    Boolean        @default(false)
  allowedUsers    String[]       @default([]) // For confidential matters
  tags            String[]
  metadata        Json? // CAC checklist, jurisdiction-specific fields
  openDate        DateTime       @default(now())
  closeDate       DateTime?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  tasks           MatterTask[]
  timeEntries     TimeEntry[]
  documents       Document[]
}

model MatterTask {
  id          String         @id @default(uuid())
  matterId    String
  matter      Matter         @relation(fields: [matterId], references: [id])
  title       String
  description String?
  assigneeId  String?
  status      TaskStatus     @default(TODO)
  priority    MatterPriority @default(MEDIUM)
  dueDate     DateTime?
  completedAt DateTime?
  createdBy   String
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
}

model TimeEntry {
  id          String   @id @default(uuid())
  matterId    String
  matter      Matter   @relation(fields: [matterId], references: [id])
  userId      String
  description String
  hours       Decimal  @db.Decimal(6, 2)
  rate        Decimal  @db.Decimal(10, 2)
  currency    String   @default("GBP")
  date        DateTime
  billed      Boolean  @default(false)
  createdAt   DateTime @default(now())
}

model AuditCertificate {
  id             String   @id @default(uuid())
  orgId          String
  orgSlug        String
  generatedBy    String
  eventCount     Int
  startTime      DateTime
  endTime        DateTime
  fingerprint    String // SHA-256 hash of the events
  certificateUrl String?
  createdAt      DateTime @default(now())

  organisation Organisation @relation(fields: [orgId], references: [id])

  @@index([orgId])
}

enum WorkspaceType {
  LITIGATION
  CORPORATE
  EMPLOYMENT
  REAL_ESTATE
  IP
  COMPLIANCE
  GENERAL
}

enum WorkspaceStatus {
  ACTIVE
  ARCHIVED
}

enum WorkspaceMemberRole {
  WORKSPACE_ADMIN
  MEMBER
}

enum MatterType {
  TRANSACTION
  LITIGATION
  ADVISORY
  COMPLIANCE
  RETAINER
  OTHER
}

enum PracticeArea {
  CORPORATE
  EMPLOYMENT
  COMMERCIAL
  LITIGATION
  IP
  PROPERTY
  OTHER
}

enum MatterStatus {
  ENQUIRY
  OPEN
  ACTIVE
  PENDING
  ON_HOLD
  CLOSED
  ARCHIVED
}

enum MatterPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  BLOCKED
  DONE
}
enum DocumentStatus {
  DRAFT
  UNDER_REVIEW
  PENDING_SIGNATURE
  EXECUTED
  ARCHIVED
}

enum DocumentPermission {
  READ
  WRITE
  ADMIN
}

enum DocumentAction {
  CREATE
  UPDATE
  STATE_CHANGE
  VERSION_CREATE
  ACCESS_GRANT
  ACCESS_REVOKE
  DELETE
}

enum DocumentRetentionAction {
  ARCHIVE
  DELETE
}

model Document {
  id              String                  @id @default(uuid())
  title           String
  fileName        String
  mimeType        String
  size            Int
  status          DocumentStatus          @default(DRAFT)
  isConfidential  Boolean                 @default(false)
  orgId           String
  org             Organisation            @relation(fields: [orgId], references: [id])
  workspaceId     String
  workspace       Workspace               @relation(fields: [workspaceId], references: [id])
  matterId        String?
  matter          Matter?                 @relation(fields: [matterId], references: [id])
  metadata        Json?
  currentVersion   Int                     @default(1)
  retentionDate    DateTime?
  retentionAction  DocumentRetentionAction @default(ARCHIVE)
  parentDocumentId String?
  parentDocument   Document?               @relation("DocumentBranches", fields: [parentDocumentId], references: [id])
  createdBy        String
  createdAt        DateTime                @default(now())
  updatedAt        DateTime                @updatedAt

  versions DocumentVersion[]
  branches Document[]        @relation("DocumentBranches")
  access   DocumentAccess[]
  audit    DocumentAudit[]

  @@index([orgId, workspaceId])
  @@index([matterId])
}

model DocumentVersion {
  id             String   @id @default(uuid())
  documentId     String
  document       Document @relation(fields: [documentId], references: [id])
  versionNumber  Int
  fileKey        String // S3/Storage pointer
  size           Int
  changeLog      String?
  metadata       Json?
  isMajor        Boolean  @default(false)
  isCurrent      Boolean  @default(false)
  createdBy      String
  createdAt      DateTime @default(now())

  @@unique([documentId, versionNumber])
}

model DocumentAccess {
  id         String             @id @default(uuid())
  documentId String
  document   Document           @relation(fields: [documentId], references: [id])
  userId     String
  permission DocumentPermission @default(READ)
  grantedBy  String
  grantedAt  DateTime           @default(now())

  @@unique([documentId, userId])
}

model DocumentAudit {
  id         String         @id @default(uuid())
  documentId String
  document   Document       @relation(fields: [documentId], references: [id])
  userId     String
  user       User           @relation(fields: [userId], references: [id])
  action     DocumentAction
  details    Json?
  ipAddress  String?
  createdAt  DateTime       @default(now())

  @@index([documentId])
}

enum TemplateTier {
  CURATED
  PROFESSIONAL
  COMMUNITY
}

enum TemplateStatus {
  DRAFT
  PENDING_REVIEW
  PUBLISHED
  REJECTED
  DEPRECATED
}

model TemplateCategory {
  id          String     @id @default(uuid())
  name        String     @unique
  description String?
  templates   Template[]
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
}

model Template {
  id                   String           @id @default(uuid())
  title                String
  description          String?
  tier                 TemplateTier     @default(COMMUNITY)
  status               TemplateStatus   @default(DRAFT)
  categoryId           String
  category             TemplateCategory @relation(fields: [categoryId], references: [id])
  orgId                String? // Nullable if marketplace/global template
  org                  Organisation?    @relation(fields: [orgId], references: [id])
  currentVersion       String           @default("1.0.0")
  price                Decimal?         @default(0.00) @db.Decimal(10, 2)
  jurisdictions        String[]
  practiceArea         String?
  linkedStatutes       Json?            @default("[]")
  knowledgeGraphNodeId String? // Stub for Knowledge Graph linkage
  tags                 String[]
  createdBy            String
  createdAt            DateTime         @default(now())
  updatedAt            DateTime         @updatedAt

  versions TemplateVersion[]
  reviews  TemplateReview[]
}

model TemplateVersion {
  id         String   @id @default(uuid())
  templateId String
  template   Template @relation(fields: [templateId], references: [id])
  version    String // Semver: 1.0.0
  fileKey    String // S3 key for the template file
  changeLog  String?
  metadata   Json? // Stores variable placeholders, etc.
  createdBy  String
  createdAt  DateTime @default(now())
}

model TemplateReview {
  id         String         @id @default(uuid())
  templateId String
  template   Template       @relation(fields: [templateId], references: [id])
  reviewerId String
  status     TemplateStatus @default(PENDING_REVIEW)
  comments   String?
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt
}
