# Database
DATABASE_URL=postgresql://postgres:password@localhost:5432/largence_auth

# Redis
REDIS_URL=redis://localhost:6379

# Kafka
KAFKA_BROKERS=localhost:9092
KAFKA_CLIENT_ID=largence-auth

# Security
# Generate using: openssl genrsa -out private.pem 2048 && openssl rsa -in private.pem -pubout -out public.pem
JWT_PRIVATE_KEY="---BEGIN RSA PRIVATE KEY---\n...\n---END RSA PRIVATE KEY---"
JWT_PUBLIC_KEY="---BEGIN PUBLIC KEY---\n...\n---END PUBLIC KEY---"
JWT_ACCESS_TTL=900
JWT_REFRESH_TTL=604800
JWT_ISSUER=https://auth.largence.com

# Encryption
# 32 bytes hex
AES_ENCRYPTION_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef
AES_IV_LENGTH=12

# Argon2
ARGON2_TIME_COST=3
ARGON2_MEMORY_COST=65536
ARGON2_PARALLELISM=4

# AWS
AWS_REGION=eu-west-2
AWS_SES_FROM_ADDRESS=noreply@largence.com

# Domain
BASE_DOMAIN=largence.com
FRONTEND_URL=https://app.largence.com
AUTH_SERVICE_URL=https://auth.largence.com

# Others
ZXCVBN_MIN_SCORE=3
NODE_ENV=development
