# Database & Redis
DATABASE_URL="postgresql://postgres:password@localhost:5432/largence_db?schema=public"
REDIS_URL="redis://localhost:6379"

# Security (JWT RS256)
# Generate with: openssl genrsa -out private.pem 2048 && openssl rsa -in private.pem -pubout -out public.pem
JWT_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----"
JWT_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----"
JWT_ACCESS_TTL="15m"
JWT_REFRESH_TTL="7d"

# Encryption (AES-256-GCM)
AES_ENCRYPTION_KEY="0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef"

# Email (Resend)
RESEND_API_KEY="re_123456789"
EMAIL_FROM="Largence <no-reply@largence.com>"

# Tenancy
BASE_DOMAIN="largence.com"
FRONTEND_URL="https://app.largence.com"

# Kafka (Optional)
KAFKA_BROKERS="localhost:9092"
KAFKA_CLIENT_ID="largence-auth"

# System
NODE_ENV="development"
PORT=3000
